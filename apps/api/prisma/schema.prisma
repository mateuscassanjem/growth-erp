generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  MANAGER
  CASHIER
  ADMIN
}

enum CompanyStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum ProductType {
  PRODUCT
  SERVICE
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
  CANCELLED
}

enum PaymentMethod {
  BANK_TRANSFER
  MULTICAIXA
  MANUAL
}

enum SubscriptionStatus {
  FREE
  ACTIVE
  PENDING
  EXPIRED
  CANCELLED
}

model Company {
  id              String        @id @default(uuid())
  name            String
  taxNumber       String?
  email           String?
  phone           String?
  address         String?
  logoUrl         String?
  status          CompanyStatus @default(PENDING)
  vatRate         Decimal       @default(14.00) @db.Decimal(5, 2)
  invoiceSequence Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  users         User[]
  customers     Customer[]
  products      Product[]
  invoices      Invoice[]
  invoiceLines  InvoiceLine[]
  auditLogs     AuditLog[]
  subscriptions Subscription[]
  payments      Payment[]
}

model User {
  id               String    @id @default(uuid())
  companyId        String
  lastCompanyId    String?
  email            String    @unique
  name             String
  role             UserRole  @default(OWNER)
  passwordHash     String
  refreshTokenHash String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  company         Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  createdInvoices Invoice[]  @relation("InvoiceCreatedBy")
  auditLogs       AuditLog[]
  payments        Payment[]

  @@index([companyId])
  @@index([lastCompanyId])
}

model Customer {
  id        String   @id @default(uuid())
  companyId String
  name      String
  email     String?
  phone     String?
  taxNumber String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  invoices Invoice[]

  @@index([companyId])
}

model Product {
  id           String      @id @default(uuid())
  companyId    String
  type         ProductType @default(PRODUCT)
  name         String
  sku          String?
  description  String?
  price        Decimal     @db.Decimal(12, 2)
  stock        Decimal     @default(0) @db.Decimal(12, 3)
  stockMinimum Decimal     @default(0) @db.Decimal(12, 3)
  taxRate      Decimal     @default(14.00) @db.Decimal(5, 2)
  active       Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  invoiceLines InvoiceLine[]

  @@unique([companyId, sku])
  @@index([companyId])
  @@index([companyId, active])
  @@index([companyId, type])
}

model Invoice {
  id           String        @id @default(uuid())
  companyId    String
  customerId   String?
  createdById  String?
  series       String        @default("A")
  number       String?
  status       InvoiceStatus @default(DRAFT)
  subtotal     Decimal       @db.Decimal(12, 2)
  vatTotal     Decimal       @db.Decimal(12, 2)
  total        Decimal       @db.Decimal(12, 2)
  cancelReason String?
  fiscalHash   String?
  qrCode       String?
  issuedAt     DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  company   Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  customer  Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdBy User?         @relation("InvoiceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  lines     InvoiceLine[]

  @@unique([companyId, series, number])
  @@index([companyId])
  @@index([companyId, series])
  @@index([companyId, status])
  @@index([customerId])
  @@index([createdById])
}

model InvoiceLine {
  id          String  @id @default(uuid())
  companyId   String
  invoiceId   String
  productId   String?
  description String
  quantity    Decimal @db.Decimal(12, 3)
  unitPrice   Decimal @db.Decimal(12, 2)
  vatRate     Decimal @db.Decimal(5, 2)
  taxAmount   Decimal @db.Decimal(12, 2)
  lineTotal   Decimal @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  company Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([invoiceId])
  @@index([productId])
}

model AuditLog {
  id        String   @id @default(uuid())
  companyId String
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([companyId, entity])
  @@index([userId])
  @@index([createdAt])
}

model SubscriptionPlan {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  description String?
  features    Json?
  price       Decimal  @db.Decimal(12, 2)
  currency    String   @default("AOA")
  maxUsers    Int?
  maxInvoices Int?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id        String             @id @default(uuid())
  companyId String
  planId    String
  status    SubscriptionStatus @default(FREE)
  startsAt  DateTime?
  endsAt    DateTime?
  trialEndsAt DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  company  Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  plan     SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)
  payments Payment[]

  @@index([companyId])
  @@index([planId])
  @@index([companyId, status])
}

model Payment {
  id             String        @id @default(uuid())
  companyId      String
  subscriptionId String?
  userId         String?
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  amount         Decimal       @db.Decimal(12, 2)
  currency       String        @default("AOA")
  reference      String?
  providerRef    String?
  notes          String?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([subscriptionId])
  @@index([userId])
  @@index([companyId, status])
  @@index([reference])
}
